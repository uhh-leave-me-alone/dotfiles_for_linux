{
    //"position": "bottom",
    "height": 32,
    "spacing": 1,

    "modules-left": [
        "hyprland/workspaces",
        "hyprland/submap",
        "hyprland/language",
        "power-profiles-daemon"
    ],
    "modules-center": [
        "hyprland/window"
    ],
    "modules-right": [
        "pulseaudio",
        "network",
        "cpu",
        "memory",
        "backlight",
        //"battery",
        //"power-profiles-daemon",
        //"sway/language",
        "clock",
        "custom/date",
        "tray"
    ],

    "sway/window": {
        "max-length": 50
    },

    "hyprland/workspaces": {
        "format": "{id}",
        "on-click": "activate"
    },

    "sway/scratchpad": {
        "format": "{icon} {count}",
        "show-empty": false,
        "format-icons": ["", ""],
        "tooltip": true,
        "tooltip-format": "{app}: {title}"
    },

    "power-profiles-daemon": {
        "format": "{icon}",
        "tooltip-format": "Power profile: {profile}\nDriver: {driver}",
        "tooltip": true,
        "format-icons": {
            "default": "DEF",
            "performance": "PERF",
            "balanced": "BAL",
            "power-saver": "ECO"
        }
    },

    "clock": {
        "format": "{:%H:%M}",
        //"format-alt": "{:%Y-%m-%d}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
    },

    "custom/date": {
        "format": "{}",
        "exec":"date '+%d.%m.%Y'",
        "interval":60
    },

    "cpu": {
        "format": "CPU {usage}%",
        "interval": 2,
        "tooltip": false
    },

    "memory": {
        "format": "RAM {used:0.1f}G/{total:0.1f}G",
        "interval": 2
    },

    "backlight": {
        "format": "BRT {percent}%"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "BAT {capacity}%",
        "format-charging": "CHR {capacity}%",
        "format-plugged": "PLG {capacity}%",
        "format-full": "FULL {capacity}%"
    },

    "network": {
        "format-wifi": "WIFI {signalStrength}%",
        "format-ethernet": "ETH {ipaddr}",
        "format-disconnected": "OFFLINE",
        "tooltip-format": "{ifname} via {gwaddr}"
    },

    "pulseaudio": {
        "format": "VOL {volume}%",
        "format-muted": "MUTE",
        "on-click": "pavucontrol"
    },

    "tray": {
        "spacing": 10
    }
}
