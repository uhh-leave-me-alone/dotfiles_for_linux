# Default config for sway
#
# Copy this to ~/.config/sway/config and edit it to your liking.
#
# Read `man 5 sway` for a complete reference.

### Variables
#
# Logo key. Use Mod1 for Alt.
set $mod Mod4

# Home row direction keys, like vim
set $left h
set $down j
set $up k
set $right l

# Your preferred terminal emulator
set $term kitty

# Your preferred font (user added)
font pango:JetBrainsMono Nerd Font 11

# Your preferred gaps (user added). I decided to get rid of the gaps lol
gaps inner 0
gaps outer 0
smart_gaps on
#smart_gaps on for a situation where you have only one opened window on a screen and decide to open another one: when there is only one, gaps is turned off, when another appears - turns on.

# Your preferred window borders (user added)
default_border pixel 10
default_floating_border pixel 10

# Your preferred application launcher
set $menu wmenu-run

include /etc/sway/config-vars.d/*

### Output configuration
